{
  "$schema": "https://mintlify.com/schema.json",
  "name": "NoteFlow",
  "logo": {
    "dark": "/logo/icon-128.png",
    "light": "/logo/icon-128.png"
  },
  "favicon": "/logo/icon-128.png",
  "colors": {
    "primary": "#2563EB",
